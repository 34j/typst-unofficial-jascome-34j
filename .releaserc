plugins:
  - "@semantic-release/commit-analyzer"
  - "@semantic-release/release-notes-generator"
  - "@semantic-release/changelog"
  - - "@semantic-release/exec"
    # typst.toml
    # Replace "version = \".*\"" with "version = \"${nextRelease.version}\""
    # See below for contexts:
    # https://github.com/semantic-release/semantic-release/blob/master/docs/developer-guide/plugin.md#context
    - prepareCmd: |
        sed -i -E "s/version = \".*\"/version = \"${nextRelease.version}\"/" typst.toml
    # 0. Read package name from typst.toml
    # 1. Clone https://github.com/34j/packages to temporarily directory
    # 2. Create a version named directory
    # 3. Copy all files to the version named directory
    # 4. Move to the git repository
    # 5. Somewhat need to run "gh auth setup-git" to setup git authentication for gh cli
    # 6. Commit and create a PR
      publishCmd: >
        NAME=$(sed -nE 's/name\s*=\s*"(.*)"/\1/p' typst.toml) &&
        git clone "https://github.com/34j/packages" /tmp/packages &&
        mkdir -p "/tmp/packages/preview/$NAME/${nextRelease.version}" &&
        cp -r ./* "/tmp/packages/preview/$NAME/${nextRelease.version}/" &&
        cd /tmp/packages &&
        gh auth setup-git &&
        git switch -c "$NAME/${nextRelease.version}" &&
        git add . &&
        git commit -m "$NAME:${nextRelease.version}" &&
        git push origin "$NAME/${nextRelease.version}" &&
        gh pr create
        --title="$NAME:${nextRelease.version}"
        --repo="34j/packages"
        --head="$NAME/${nextRelease.version}"
        --body="I am submitting

        - [ ] a new package

        - [x] an update for a package

        ${nextRelease.notes}"
  - - "@semantic-release/git"
    # Commit changes to version files and changelog
    - assets:
        - CHANGELOG.md
        - typst.toml
  - - "@semantic-release/github"
