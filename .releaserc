plugins:
  - "@semantic-release/commit-analyzer"
  - "@semantic-release/release-notes-generator"
  - "@semantic-release/changelog"
  - - "@semantic-release/exec"
    # typst.toml
    # Replace "version = \".*\"" with "version = \"${nextRelease.version}\""
    # Replace README import version using the package name from typst.toml
    # See below for contexts:
    # https://github.com/semantic-release/semantic-release/blob/master/docs/developer-guide/plugin.md#context
    - prepareCmd: |
        NAME=$(sed -nE 's/name\s*=\s*"(.*)"/\1/p' typst.toml) &&
        sed -i -E "s/version = \".*\"/version = \"${nextRelease.version}\"/" typst.toml &&
        sed -i -E "s|@preview/$NAME:[^\"]*|@preview/$NAME:${nextRelease.version}|g" README.md &&
        find template -name "*.typ" -exec sed -i -E "s|@preview/$NAME:[^\"]*|@preview/$NAME:${nextRelease.version}|g" {} +
    # 0. Read package name from typst.toml
    # 1. Clone https://github.com/34j/packages to temporarily directory
    # 2. Create a version named directory
    # 3. Copy all files to the version named directory
    # 4. Remove development-only files from the published copy
    # 5. Move to the git repository
    # 6. Somewhat need to run "gh auth setup-git" to setup git authentication for gh cli
    # 7. Commit and create a PR
      publishCmd: >
        NAME=$(sed -nE 's/name\s*=\s*"(.*)"/\1/p' typst.toml) &&
        mkdir -p "/tmp/packages/packages/preview/$NAME/${nextRelease.version}" &&
        ( cp typst.toml "/tmp/packages/packages/preview/$NAME/${nextRelease.version}/" 2>/dev/null || true ) &&
        ( cp thumbnail.png "/tmp/packages/packages/preview/$NAME/${nextRelease.version}/" 2>/dev/null || true ) &&
        ( cp README* "/tmp/packages/packages/preview/$NAME/${nextRelease.version}/" 2>/dev/null || true ) &&
        ( cp LICENSE* "/tmp/packages/packages/preview/$NAME/${nextRelease.version}/" 2>/dev/null || true ) &&
        ( cp -r src "/tmp/packages/packages/preview/$NAME/${nextRelease.version}/src" 2>/dev/null || true ) &&
        ( cp -r template "/tmp/packages/packages/preview/$NAME/${nextRelease.version}/template" 2>/dev/null || true ) &&
        find "/tmp/packages/packages/preview/$NAME/${nextRelease.version}" -name "*.pdf" -delete &&
        cd /tmp/packages &&
        gh auth setup-git &&
        git switch -c "$NAME/${nextRelease.version}" &&
        git add . &&
        git commit -m "$NAME:${nextRelease.version}" &&
        git push origin "$NAME/${nextRelease.version}" &&
        gh pr create
        --title="$NAME:${nextRelease.version}"
        --repo="34j/packages"
        --head="$NAME/${nextRelease.version}"
        --body="I am submitting

        - [ ] a new package

        - [x] an update for a package

        ${nextRelease.notes}"
  - - "@semantic-release/git"
    # Commit changes to version files and changelog
    - assets:
        - CHANGELOG.md
        - typst.toml
        - README.md
        - "*.typ"
  - - "@semantic-release/github"
